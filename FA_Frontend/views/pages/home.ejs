<section class="hero">
  <div class="hero-layout">
    <div class="hero-content">
      <p class="eyebrow">AI-powered anti-scam portal</p>
      <h1><%= page.heading %></h1>
      <p class="tagline"><%= page.tagline %></p>
      <p class="hero-description"><%= page.description %></p>
    </div>
    <div class="hero-logo-card">
      <img src="/images/sparklebot-logo.png" alt="SparkleBot logo: Protect. Detect. Prevent.">
    </div>
  </div>
</section>

<section class="content-section home-video-section">
  <div class="home-video-card">
    <video class="home-video" controls preload="metadata">
      <source src="<%= page.videoSrc %>" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </div>
</section>

<section class="content-section home-dashboard-section">
  <div class="section-heading">
    <h2>Dashboard Functions</h2>
    <p>Key tools for checking suspicious content, getting guidance, recording reports, and reviewing scam insights.</p>
  </div>
  <div class="card-grid home-feature-grid">
    <% features.forEach((featureGroup) => { %>
      <article class="card feature-card">
        <h3><%= featureGroup.title %></h3>
        <p><%= featureGroup.description %></p>
        <div class="feature-link-row" aria-label="<%= featureGroup.title %> links">
          <% featureGroup.links.forEach((link) => { %>
            <a class="text-link" href="<%= link.href %>"><%= link.label %></a>
          <% }) %>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="content-section promotional-artefacts-section">
  <div class="section-heading">
    <h2>Promotional Artefacts</h2>
    <p>Explore SparkleBot's scam-awareness posters and download a PDF copy for your own viewing.</p>
  </div>

  <div class="promotional-artefacts-grid">
    <article class="card promotional-artefact-card">
      <a class="poster-preview-link" href="/images/promotional/how-sparklebot-works.png" target="_blank" rel="noopener">
        <img
          class="promotional-poster"
          src="/images/promotional/how-sparklebot-works.png"
          alt="How SparkleBot Works promotional poster"
          loading="lazy"
        >
      </a>
      <div class="promotional-artefact-content">
        <h3>How SparkleBot Works</h3>
        <p>Discover SparkleBot's scam detection, guidance, reporting, trends, simulation, and quiz features.</p>
        <div class="promotional-artefact-actions">
          <a class="btn btn-secondary" href="/images/promotional/how-sparklebot-works.png" target="_blank" rel="noopener">View Poster</a>
          <a class="btn btn-primary" href="/downloads/how-sparklebot-works.pdf" download="how-sparklebot-works.pdf">Download PDF</a>
        </div>
      </div>
    </article>

    <article class="card promotional-artefact-card">
      <a class="poster-preview-link" href="/images/promotional/why-sparklebot-matters.png" target="_blank" rel="noopener">
        <img
          class="promotional-poster"
          src="/images/promotional/why-sparklebot-matters.png"
          alt="Why SparkleBot Matters promotional poster"
          loading="lazy"
        >
      </a>
      <div class="promotional-artefact-content">
        <h3>Why SparkleBot Matters</h3>
        <p>Learn about the scam problem and how SparkleBot provides smarter, explainable scam protection.</p>
        <div class="promotional-artefact-actions">
          <a class="btn btn-secondary" href="/images/promotional/why-sparklebot-matters.png" target="_blank" rel="noopener">View Poster</a>
          <a class="btn btn-primary" href="/downloads/why-sparklebot-matters.pdf" download="why-sparklebot-matters.pdf">Download PDF</a>
        </div>
      </div>
    </article>
  </div>
</section>
