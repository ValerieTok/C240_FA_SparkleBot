<section class="hero">
  <div class="hero-layout">
    <div class="hero-content">
      <p class="eyebrow">AI-powered anti-scam portal</p>
      <h1><%= page.heading %></h1>
      <p class="tagline"><%= page.tagline %></p>
      <p class="hero-description"><%= page.description %></p>
    </div>
    <div class="hero-logo-card">
      <img src="/images/sparklebot-logo.png" alt="SparkleBot logo: Protect. Detect. Prevent.">
    </div>
  </div>
</section>

<section class="content-section home-video-section">
  <div class="home-video-card">
    <video class="home-video" controls preload="metadata">
      <source src="<%= page.videoSrc %>" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </div>
</section>

<section class="content-section home-dashboard-section">
  <div class="section-heading">
    <h2>Dashboard Functions</h2>
    <p>Key tools for checking suspicious content, getting guidance, recording reports, and reviewing scam insights.</p>
  </div>
  <div class="card-grid home-feature-grid">
    <% features.forEach((featureGroup) => { %>
      <article class="card feature-card">
        <h3><%= featureGroup.title %></h3>
        <p><%= featureGroup.description %></p>
        <div class="feature-link-row" aria-label="<%= featureGroup.title %> links">
          <% featureGroup.links.forEach((link) => { %>
            <a class="text-link" href="<%= link.href %>"><%= link.label %></a>
          <% }) %>
        </div>
      </article>
    <% }) %>
  </div>
</section>
