<section class="page-hero compact">
  <h1><%= page.heading %></h1>
  <p><%= page.description %></p>
</section>

<section class="content-section two-column chatbot-layout">
  <article class="chatbot-panel">
    <h2>Chat With SparkleBot</h2>
    <div
      id="sparklebot-webchat"
      class="webchat-box"
      data-bot-name="<%= botpress.botName %>"
    >
      <div class="webchat-loading">
        <p>Loading SparkleBot...</p>
      </div>
    </div>
  </article>

  <aside class="card">
    <% if (scamContext) { %>
      <section class="chatbot-handoff">
        <h2>Scam Context</h2>
        <dl class="result-list">
          <div>
            <dt>Risk Level</dt>
            <dd><%= scamContext.riskLevel %></dd>
          </div>
          <% if (scamContext.score) { %>
            <div>
              <dt>Score</dt>
              <dd><%= scamContext.score %>/100</dd>
            </div>
          <% } %>
          <div>
            <dt>Possible Scam Type</dt>
            <dd><%= scamContext.scamType %></dd>
          </div>
          <div>
            <dt>Red Flags</dt>
            <dd><%= scamContext.redFlags || "None returned" %></dd>
          </div>
          <div>
            <dt>Recommended Action</dt>
            <dd><%= scamContext.recommendedAction || "None returned" %></dd>
          </div>
        </dl>
      </section>
    <% } %>

    <h2>Example Questions</h2>
    <ul class="check-list">
      <% questions.forEach((question) => { %>
        <li><%= question %></li>
      <% }) %>
    </ul>
  </aside>
</section>

<% if (botpress.webchatInjectUrl) { %>
  <script src="<%= botpress.webchatInjectUrl %>"></script>
<% } %>
<% if (botpress.webchatConfigUrl) { %>
  <script src="<%= botpress.webchatConfigUrl %>" defer></script>
<% } %>
<script src="/js/chatbot.js" defer></script>
