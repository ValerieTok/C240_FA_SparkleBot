<section class="page-hero compact">
  <h1><%= page.heading %></h1>
  <p><%= page.description %></p>
</section>

<section class="content-section two-column">
  <article class="chatbot-panel">
    <h2>Chat With SparkleBot</h2>
    <div
      id="sparklebot-webchat"
      class="webchat-box"
      data-bot-name="<%= botpress.botName %>"
    >
      <div class="webchat-loading">
        <p>Loading SparkleBot...</p>
      </div>
    </div>
  </article>

  <aside class="card">
    <h2>Example Questions</h2>
    <ul class="check-list">
      <% questions.forEach((question) => { %>
        <li><%= question %></li>
      <% }) %>
    </ul>
  </aside>

  <aside class="card">
    <h2>Feedback</h2>
    <form action="/feedback" method="POST">
      <input type="hidden" name="page" value="chatbot">

      <% if (feedbackMessage) { %>
        <p class="form-status success"><%= feedbackMessage %></p>
      <% } %>

      <% if (feedbackError) { %>
        <p class="form-status error"><%= feedbackError %></p>
      <% } %>

      <fieldset class="choice-group">
        <legend>Was SparkleBot helpful?</legend>
        <label>
          <input type="radio" name="rating" value="helpful" required>
          Helpful
        </label>
        <label>
          <input type="radio" name="rating" value="not_helpful" required>
          Not helpful
        </label>
      </fieldset>

      <label for="feedbackComment">Comment (optional)</label>
      <textarea id="feedbackComment" name="comment" rows="4" placeholder="What should be improved?"></textarea>

      <button class="btn btn-primary" type="submit">Send Feedback</button>
    </form>
  </aside>
</section>

<% if (botpress.webchatInjectUrl) { %>
  <script src="<%= botpress.webchatInjectUrl %>"></script>
<% } %>
<% if (botpress.webchatConfigUrl) { %>
  <script src="<%= botpress.webchatConfigUrl %>" defer></script>
<% } %>
<script src="/js/chatbot.js" defer></script>
