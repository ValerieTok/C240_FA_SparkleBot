<section class="page-hero compact">
  <h1><%= page.heading %></h1>
  <p><%= page.description %></p>
</section>

<section class="tool-panel report-layout">
  <form class="form-card report-page-card" action="/report-scam" method="POST">
    <% if (reportMessage) { %>
      <p class="form-status success"><%= reportMessage %></p>
    <% } %>

    <% if (reportError) { %>
      <p class="form-status error"><%= reportError %></p>
    <% } %>

    <label for="scamTypeInput">Scam type</label>
    <select id="scamTypeInput" name="scamType" required>
      <option value="">Select scam type</option>
      <option value="Phishing" <%= values.scamType === 'Phishing' ? 'selected' : '' %>>Phishing</option>
      <option value="Job scam" <%= values.scamType === 'Job scam' ? 'selected' : '' %>>Job scam</option>
      <option value="Payment scam" <%= values.scamType === 'Payment scam' ? 'selected' : '' %>>Payment scam</option>
      <option value="Impersonation scam" <%= values.scamType === 'Impersonation scam' ? 'selected' : '' %>>Impersonation scam</option>
      <option value="Investment scam" <%= values.scamType === 'Investment scam' ? 'selected' : '' %>>Investment scam</option>
      <option value="Other" <%= values.scamType === 'Other' ? 'selected' : '' %>>Other</option>
    </select>

    <label for="platformInput">Where did it happen?</label>
    <input
      id="platformInput"
      name="platform"
      type="text"
      placeholder="SMS, WhatsApp, Telegram, email, website, etc."
      value="<%= values.platform || '' %>"
      required
    >

    <label for="reportMessageInput">Scam details</label>
    <textarea
      id="reportMessageInput"
      name="message"
      rows="7"
      placeholder="Paste the scam message or describe what happened..."
      required
    ><%= values.message || '' %></textarea>

    <label for="contactInput">Contact email <span>(optional)</span></label>
    <input
      id="contactInput"
      name="contact"
      type="email"
      placeholder="name@example.com"
      value="<%= values.contact || '' %>"
    >

    <button class="btn btn-primary" type="submit">Submit Report</button>
  </form>
</section>
