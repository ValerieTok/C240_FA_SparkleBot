<section class="page-hero compact">
  <h1><%= page.heading %></h1>
  <p><%= page.description %></p>
</section>

<section class="tool-panel">
  <form class="form-card" action="/upload" method="POST" enctype="multipart/form-data" data-analysis-form>
    <label for="screenshotInput">Upload screenshot image</label>
    <input id="screenshotInput" name="screenshot" type="file" accept="image/*" required>
    <button class="btn btn-primary" type="submit">Analyze Screenshot</button>
    <div class="analysis-loading hidden" data-analysis-loading role="status" aria-live="polite">
      <span class="loading-spinner" aria-hidden="true"></span>
      <span>Reading and analyzing screenshot… This may take a few seconds.</span>
    </div>
  </form>

  <% if (errorMessage) { %>
    <article class="result-card">
      <h2>Analysis Error</h2>
      <p><%= errorMessage %></p>
    </article>
  <% } %>

  <article class="preview-card <%= uploadedImage ? '' : 'hidden' %>" id="screenshotPreviewCard">
    <h2>Screenshot Preview</h2>
    <img id="screenshotPreview" src="<%= uploadedImage || '' %>" alt="Uploaded scam screenshot preview">
  </article>

  <% if (extractedText) { %>
    <article class="result-card" aria-live="polite">
      <h2>Extracted Text</h2>
      <p><%= extractedText %></p>
    </article>
  <% } %>

  <% if (analysis) { %>
    <article class="result-card" aria-live="polite">
      <h2>Scam Risk Analysis</h2>
      <p><strong>Risk Level:</strong> <%= analysis.riskLevel %></p>
      <p><strong>Possible Scam Type:</strong> <%= analysis.scamType %></p>
      <p><strong>Red Flags:</strong> <%= analysis.redFlags.join(", ") %></p>
      <p><strong>Recommended Action:</strong> <%= analysis.recommendedAction %></p>
    </article>
  <% } %>

  <form class="form-card" action="/report-scam" method="POST">
    <h2>Report Scam</h2>
    <p class="form-note">Submit suspicious activity for admin review through n8n.</p>

    <% if (reportMessage) { %>
      <p class="form-status success"><%= reportMessage %></p>
    <% } %>

    <% if (reportError) { %>
      <p class="form-status error"><%= reportError %></p>
    <% } %>

    <label for="scamTypeInput">Scam type</label>
    <select id="scamTypeInput" name="scamType" required>
      <option value="">Select scam type</option>
      <option value="Phishing">Phishing</option>
      <option value="Job scam">Job scam</option>
      <option value="Payment scam">Payment scam</option>
      <option value="Impersonation scam">Impersonation scam</option>
      <option value="Investment scam">Investment scam</option>
      <option value="Other">Other</option>
    </select>

    <label for="platformInput">Where did it happen?</label>
    <input
      id="platformInput"
      name="platform"
      type="text"
      placeholder="SMS, WhatsApp, Telegram, email, website, etc."
      required
    >

    <label for="reportMessageInput">Scam details</label>
    <textarea
      id="reportMessageInput"
      name="message"
      rows="6"
      placeholder="Paste the scam message or describe what happened..."
      required
    ></textarea>

    <label for="contactInput">Contact email (optional)</label>
    <input id="contactInput" name="contact" type="email" placeholder="name@example.com">

    <button class="btn btn-primary" type="submit">Submit Report</button>
  </form>
</section>
