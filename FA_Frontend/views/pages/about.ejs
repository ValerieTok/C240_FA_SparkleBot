<section class="page-hero compact">
  <h1><%= page.heading %></h1>
  <p><%= page.description %></p>
</section>

<section class="content-section">
  <div class="section-heading">
    <h2>Website Functions</h2>
    <p>SparkleBot brings scam checking, guidance, reporting, trend review, and feedback into one anti-scam portal.</p>
  </div>
  <div class="card-grid">
    <% websiteFunctions.forEach((websiteFunction) => { %>
      <article class="card">
        <h3><%= websiteFunction.name %></h3>
        <p><%= websiteFunction.description %></p>
        <a class="text-link" href="<%= websiteFunction.link %>"><%= websiteFunction.linkText %></a>
      </article>
    <% }) %>
  </div>
</section>

<section class="content-section">
  <div class="section-heading">
    <h2>How The AI Supports The Website</h2>
    <p>The AI features are focused on helping users understand suspicious content and make safer decisions.</p>
  </div>
  <div class="card-grid">
    <% aiWorkflow.forEach((step) => { %>
      <article class="card">
        <h3><%= step.name %></h3>
        <p><%= step.description %></p>
      </article>
    <% }) %>
  </div>
</section>
